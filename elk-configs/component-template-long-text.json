{
  "template": {
    "mappings": {
      "properties": {
        "winlog": {
          "properties": {
            "event_data": {
              "properties": {
                "CommandLine":       { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 8192 } } },
                "ParentCommandLine": { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 8192 } } },
                "Hashes":            { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 8192 } } }
              }
            }
          }
        }
      }
    }
  },
  "_meta": {
    "description": "ignore_above 8192 for long Windows fields (default 256 truncates PowerShell EncodedCommand + SHA-1/MD5/SHA-256 hash lists)",
    "managed_by": "vn-soc-lab pha10.1"
  }
}
