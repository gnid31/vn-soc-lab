<!--
  VN-SOC Pha 13 — Wazuh Agent syscheck config bổ sung cho Win10.
  Chèn block dưới đây vào <syscheck> section trong:
    C:\Program Files (x86)\ossec-agent\ossec.conf

  Default Wazuh Agent Windows đã monitor:
    C:\Windows\System32\drivers\etc\
    C:\Windows\System32\SysWOW64\drivers\etc\
    C:\Windows\System32\wbem\
    C:\Windows\System32\WindowsPowerShell\v1.0\
  Additions dưới đây bổ sung theo lab scope.
-->

<syscheck>
  <!-- Realtime monitoring: file thay đổi trigger alert ngay lập tức -->
  <directories check_all="yes" realtime="yes" report_changes="yes">C:\Windows\System32\drivers\etc</directories>

  <!-- Startup folder — persistence artifact common location -->
  <directories check_all="yes" realtime="yes" report_changes="yes">C:\Users\ADMIN\AppData\Roaming\Microsoft\Windows\Start Menu\Programs\Startup</directories>
  <directories check_all="yes" realtime="yes" report_changes="yes">C:\ProgramData\Microsoft\Windows\Start Menu\Programs\Startup</directories>

  <!-- Scheduled tasks — persistence via schtasks -->
  <directories check_all="yes" realtime="yes">C:\Windows\System32\Tasks</directories>

  <!-- Windows Registry monitoring — Run/RunOnce keys (T1547.001 persistence) -->
  <windows_registry arch="both">HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\Run</windows_registry>
  <windows_registry arch="both">HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\RunOnce</windows_registry>
  <windows_registry arch="both">HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Run</windows_registry>
  <windows_registry arch="both">HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\RunOnce</windows_registry>

  <!-- LSASS Protection / Credential Guard settings -->
  <windows_registry arch="both">HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Control\Lsa</windows_registry>

  <!-- Windows Defender exclusion tampering (T1562.001) -->
  <windows_registry arch="both">HKEY_LOCAL_MACHINE\Software\Microsoft\Windows Defender\Exclusions</windows_registry>

  <!-- Scan frequency: default 12h. Lab dùng 30 phút để demo nhanh -->
  <frequency>1800</frequency>

  <!-- Không scan file tạm / cache -->
  <nodiff>C:\Users\*\AppData\Local\Temp\*</nodiff>
  <ignore type="sregex">.*\\Temp\\.*</ignore>
</syscheck>
